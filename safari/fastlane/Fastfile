app_store_connect_api_key(
  key_id: "UZBN452J8D",
  issuer_id: "2a0c5baa-92b0-489c-b4c7-b1771b5e6df8",
  key_filepath: "~/.appstoreconnect/private_keys/AuthKey_UZBN452J8D.p8"
)

default_platform(:mac)

def next_build_number(platform)
  latest = latest_testflight_build_number(
    app_identifier: "com.moonloaf.geospoof",
    platform: platform
  )
  latest + 1
end

platform :mac do
  desc "Build and upload macOS app to App Store Connect"
  lane :release do
    build_number = next_build_number("osx")
    increment_build_number(build_number: build_number)

    gym(
      scheme: "GeoSpoof-macOS",
      project: "GeoSpoof.xcodeproj",
      configuration: "Release",
      destination: "generic/platform=macOS",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "9445Q654K8"
      },
      output_directory: "./build",
      output_name: "GeoSpoof-macOS"
    )

    deliver(
      platform: "osx",
      skip_metadata: true,
      skip_screenshots: true,
      run_precheck_before_submit: false
    )
  end

  desc "Build, notarize, and package macOS app for direct download (Developer ID)"
  lane :developer_id do
    # Read profile UUIDs from the installed .provisionprofile files so we can
    # pass explicit specifiers to xcodebuild. Both macOS targets include the
    # App Groups entitlement, which requires an explicit profile even under
    # manual signing — passing an empty PROVISIONING_PROFILE_SPECIFIER causes
    # xcodebuild to fail with "requires a provisioning profile with App Groups".
    profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    app_profile_uuid = `/usr/libexec/PlistBuddy -c 'Print :UUID' /dev/stdin <<< $(security cms -D -i "#{profiles_dir}/geospoof_macos_app.provisionprofile")`.strip
    ext_profile_uuid = `/usr/libexec/PlistBuddy -c 'Print :UUID' /dev/stdin <<< $(security cms -D -i "#{profiles_dir}/geospoof_macos_ext.provisionprofile")`.strip

    UI.message("App profile UUID: #{app_profile_uuid}")
    UI.message("Extension profile UUID: #{ext_profile_uuid}")

    # Switch the whole archive build to manual Developer ID signing, with the
    # correct profile per target. CI runners only have the Developer ID cert
    # (no Mac Development cert), so automatic signing can't be used for the
    # archive.
    #
    # We write the signing settings directly into the project per target rather
    # than via xcargs/xcconfig: neither command-line xcargs nor a single
    # -xcconfig can be scoped per target (the only build-setting conditionals
    # are [sdk=], [arch=], [config=], [variant=] — there is no [target=]). A
    # global PROVISIONING_PROFILE therefore gets applied to every target, which
    # is exactly what produced the "profile app ID does not match bundle ID"
    # archive failure. update_code_signing_settings edits the .pbxproj per
    # target, which is unambiguous.
    {
      "GeoSpoof (macOS)" => app_profile_uuid,
      "GeoSpoof Extension (macOS)" => ext_profile_uuid
    }.each do |target_name, profile_uuid|
      update_code_signing_settings(
        path: "GeoSpoof.xcodeproj",
        use_automatic_signing: false,
        team_id: "9445Q654K8",
        code_sign_identity: "Developer ID Application",
        targets: [target_name],
        build_configurations: ["Release"],
        profile_uuid: profile_uuid
      )
    end

    gym(
      scheme: "GeoSpoof-macOS",
      project: "GeoSpoof.xcodeproj",
      configuration: "Release",
      destination: "generic/platform=macOS",
      export_method: "developer-id",
      export_options: {
        signingStyle: "manual",
        teamID: "9445Q654K8",
        provisioningProfiles: {
          "com.moonloaf.geospoof" => app_profile_uuid,
          "com.moonloaf.geospoof.Extension" => ext_profile_uuid
        }
      },
      # The "Run Script" build phase runs `npm run build:safari`, which writes
      # dist/ at the repo root — outside Xcode's user-script sandbox. The
      # project sets ENABLE_USER_SCRIPT_SANDBOXING=YES, so that write is denied
      # and the archive fails. Disable sandboxing for the archive build. This is
      # a uniform setting, so a global xcarg is the right tool here.
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO",
      output_directory: "./build",
      output_name: "GeoSpoof-macOS-DeveloperID"
    )

    app_path = "./build/GeoSpoof-macOS-DeveloperID.app"

    # Notarize the .app. The App Store Connect API key from the top of this
    # Fastfile is picked up automatically. notarize() staples on success.
    notarize(
      package: app_path,
      bundle_id: "com.moonloaf.geospoof",
      print_log: true,
      verbose: false
    )

    # Build a DMG with the notarized .app and an Applications symlink.
    sh("rm -rf ../build/dmg-staging ../build/GeoSpoof.dmg")
    sh("mkdir -p ../build/dmg-staging")
    sh("cp -R '../build/GeoSpoof-macOS-DeveloperID.app' '../build/dmg-staging/GeoSpoof.app'")
    sh("ln -sf /Applications ../build/dmg-staging/Applications")
    sh("hdiutil create -volname 'GeoSpoof' -srcfolder ../build/dmg-staging -ov -format UDZO ../build/GeoSpoof.dmg")
    sh("rm -rf ../build/dmg-staging")

    # Notarize and staple the DMG itself so Gatekeeper accepts it offline.
    notarize(
      package: "./build/GeoSpoof.dmg",
      bundle_id: "com.moonloaf.geospoof.dmg",
      print_log: true,
      verbose: false
    )

    UI.success("Notarized DMG: build/GeoSpoof.dmg")
  end
end

platform :ios do
  desc "Build and upload iOS app to App Store Connect"
  lane :release do
    build_number = next_build_number("ios")
    increment_build_number(build_number: build_number)

    gym(
      scheme: "GeoSpoof-iOS",
      project: "GeoSpoof.xcodeproj",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "9445Q654K8"
      },
      output_directory: "./build",
      output_name: "GeoSpoof-iOS"
    )

    deliver(
      platform: "ios",
      skip_metadata: true,
      skip_screenshots: true,
      run_precheck_before_submit: false
    )
  end

  desc "CI: build + upload iOS App Store build with manual Apple Distribution signing"
  lane :app_store_ci do
    # CI runners have no logged-in Apple account, so automatic signing can't be
    # used for an App Store archive. Sign manually with the Apple Distribution
    # cert + explicit App Store provisioning profiles per target — the same
    # approach the macOS `developer_id` lane uses (which is proven on CI).
    #
    # Profiles are installed by the workflow into the standard directory. Read
    # each one's UUID so we can pass explicit specifiers to xcodebuild (App
    # Groups require an explicit profile even under manual signing).
    profiles_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    read_uuid = lambda do |file|
      `/usr/libexec/PlistBuddy -c 'Print :UUID' /dev/stdin <<< $(security cms -D -i "#{file}")`.strip
    end
    app_uuid    = read_uuid.call("#{profiles_dir}/geospoof_ios_app.mobileprovision")
    ext_uuid    = read_uuid.call("#{profiles_dir}/geospoof_ios_ext.mobileprovision")
    widget_uuid = read_uuid.call("#{profiles_dir}/geospoof_ios_widget.mobileprovision")

    UI.message("App profile UUID: #{app_uuid}")
    UI.message("Extension profile UUID: #{ext_uuid}")
    UI.message("Widget profile UUID: #{widget_uuid}")

    # Write manual signing settings per target. Per-target (not a global xcarg)
    # because each target has a distinct bundle ID + profile; a global
    # PROVISIONING_PROFILE would be applied to all three and mismatch two of them.
    {
      "GeoSpoof (iOS)"           => app_uuid,
      "GeoSpoof Extension (iOS)" => ext_uuid,
      "GeoSpoof WidgetExtension" => widget_uuid
    }.each do |target_name, profile_uuid|
      update_code_signing_settings(
        path: "GeoSpoof.xcodeproj",
        use_automatic_signing: false,
        team_id: "9445Q654K8",
        code_sign_identity: "Apple Distribution",
        targets: [target_name],
        build_configurations: ["Release"],
        profile_uuid: profile_uuid
      )
    end

    build_number = next_build_number("ios")
    increment_build_number(build_number: build_number)

    gym(
      scheme: "GeoSpoof-iOS",
      project: "GeoSpoof.xcodeproj",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        teamID: "9445Q654K8",
        provisioningProfiles: {
          "com.moonloaf.geospoof"                => app_uuid,
          "com.moonloaf.geospoof.Extension"      => ext_uuid,
          "com.moonloaf.geospoof.GeoSpoof-Widget" => widget_uuid
        }
      },
      # Same run-script sandbox issue as the macOS archive: the build phase runs
      # `npm run build:safari`, which writes dist/ outside Xcode's script sandbox.
      xcargs: "ENABLE_USER_SCRIPT_SANDBOXING=NO",
      output_directory: "./build",
      output_name: "GeoSpoof-iOS"
    )

    deliver(
      platform: "ios",
      skip_metadata: true,
      skip_screenshots: true,
      run_precheck_before_submit: false
    )
  end
end
