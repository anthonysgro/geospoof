      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        teamID: "9445Q654K8"
      },
      output_directory: "./build",
      output_name: "GeoSpoof-iOS"
    )

    deliver(
      platform: "ios",
      skip_metadata: true,
      skip_screenshots: true,
      run_precheck_before_submit: false
    )
  end
