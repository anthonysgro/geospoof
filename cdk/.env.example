# Emails that receive the CloudFront 5xx alarm and the monthly cost-budget
# notifications, per environment. Kept out of the repo (the real values go in a
# gitignored cdk/.env, which lib/config/app.ts loads automatically).
#
# Per-env vars are preferred so dev and prod alerts land in different inboxes.
# GEOSPOOF_ALARM_EMAIL (no suffix) is an optional shared fallback for either.
#
# If none is set, the alarm topic is still created (no subscriber) and the
# budget is skipped.
#
GEOSPOOF_ALARM_EMAIL_DEV=
GEOSPOOF_ALARM_EMAIL_PROD=
