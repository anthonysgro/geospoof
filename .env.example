# Environment Configuration for GeoSpoof Extension
#
# These variables are injected at build time via Vite's `define` config.
# They replace `process.env.*` references in source code with literal values.

# Enable debug logging (only works in development mode)
DEBUG=false

# Custom event name for content/injected script communication
# Default: __geospoof_settings_update
EVENT_NAME=_gsu

# AMO API credentials for self-distribution signing (unlisted channel)
# Generate at: https://addons.mozilla.org/en-US/developers/addon/api/key/
AMO_JWT_ISSUER=
AMO_JWT_SECRET=
