{
  "_comment": [
    "Cross-language parity fixture for the Advanced Filtering Pattern_Parser.",
    "Single source of truth shared by the TypeScript parser (src/shared/utils/scope.ts",
    "parsePattern) and the native Swift parser (safari/Shared (App)/SpoofModel.swift",
    "normalizePatternInput). Both MUST produce byte-identical canonical output for every",
    "vector so that scope lists round-trip losslessly across the App Group bridge.",
    "",
    "Each entry is { input, expected } where expected is the canonical stored string, or",
    "null when the input is not a valid pattern. Expected values are hand-authored (an",
    "independent contract) — NOT re-derived from either parser — so a regression in either",
    "implementation is caught rather than masked.",
    "",
    "Consumed by:",
    "  - tests/unit/shared/pattern-vectors.test.ts (TypeScript, runs under `npm test`)",
    "  - safari/GeoSpoofTests/PatternParserParityTests.swift (Swift, runs under Xcode)",
    "",
    "Internationalized domain names (IDNs) are accepted and stored in their Unicode form",
    "(NFC-normalized + lowercased), NOT Punycode — both parsers canonicalize with native",
    "string ops only; the extension converts to A-labels at match time. The over-63-unit",
    "label rule is asserted programmatically in the two test files (not encoded here)."
  ],
  "valid": [
    { "input": "example.com", "expected": "example.com" },
    { "input": "EXAMPLE.COM", "expected": "example.com" },
    { "input": "  example.com  ", "expected": "example.com" },
    { "input": "www.example.com", "expected": "www.example.com" },
    { "input": "sub.domain.example.com", "expected": "sub.domain.example.com" },
    { "input": "example.co.uk", "expected": "example.co.uk" },
    { "input": "exàmple.com", "expected": "exàmple.com" },
    { "input": "HTTP://Example.com", "expected": "http://example.com" },
    {
      "input": "https://www.Example.com:8443/Path?q=1#h",
      "expected": "https://www.example.com:8443/Path"
    },
    { "input": "*://example.com", "expected": "*://example.com" },
    { "input": "https://*.example.com", "expected": "https://*.example.com" },
    { "input": "*.ru", "expected": "*.ru" },
    { "input": "*.su", "expected": "*.su" },
    { "input": "*.example.com", "expected": "*.example.com" },
    { "input": "*.co.uk", "expected": "*.co.uk" },
    { "input": "*.EXAMPLE.com", "expected": "*.example.com" },
    { "input": "*.localhost", "expected": "*.localhost" },
    { "input": "*.127.0.0.1", "expected": "*.127.0.0.1" },
    { "input": "*", "expected": "*" },
    { "input": "localhost", "expected": "localhost" },
    { "input": "localhost:3000", "expected": "localhost:3000" },
    { "input": "http://localhost:3000/app/*", "expected": "http://localhost:3000/app/*" },
    { "input": "site.com/app/*", "expected": "site.com/app/*" },
    { "input": "example.com/", "expected": "example.com" },
    { "input": "example.com:*", "expected": "example.com" },
    { "input": "example.com:0080", "expected": "example.com:80" },
    { "input": "example.com:0", "expected": "example.com:0" },
    { "input": "example.com:65535", "expected": "example.com:65535" },
    { "input": "EXAMPLE.com:8080", "expected": "example.com:8080" },
    { "input": "Example.COM/Path/To/Page", "expected": "example.com/Path/To/Page" },
    { "input": "example.com/a/b-c_d.e~f%20", "expected": "example.com/a/b-c_d.e~f%20" },
    { "input": "127.0.0.1", "expected": "127.0.0.1" },
    { "input": "192.168.1.1", "expected": "192.168.1.1" },
    { "input": "127.0.0.1:8080/api/*", "expected": "127.0.0.1:8080/api/*" },
    { "input": "München.de", "expected": "münchen.de" },
    { "input": "ÜBER.example.com", "expected": "über.example.com" },
    { "input": "日本.jp", "expected": "日本.jp" },
    { "input": "пример.рф", "expected": "пример.рф" },
    { "input": "*.рф", "expected": "*.рф" },
    { "input": "münchen.de:8443", "expected": "münchen.de:8443" },
    { "input": "münchen.de/Path/*", "expected": "münchen.de/Path/*" },
    { "input": "xn--wgv71a.jp", "expected": "xn--wgv71a.jp" },
    { "input": "cafe\u0301.fr", "expected": "caf\u00e9.fr" }
  ],
  "invalid": [
    { "input": "", "expected": null },
    { "input": "   ", "expected": null },
    { "input": "com", "expected": null },
    { "input": "example", "expected": null },
    { "input": "foo_bar.com", "expected": null },
    { "input": "-example.com", "expected": null },
    { "input": "example-.com", "expected": null },
    { "input": "example.com:", "expected": null },
    { "input": "example.com:12a", "expected": null },
    { "input": "example.com:99999", "expected": null },
    { "input": "example.com:123456", "expected": null },
    { "input": "1.2.3", "expected": null },
    { "input": "999.1.1.1", "expected": null },
    { "input": "1.2.3.4.5", "expected": null },
    { "input": "a.b*.com", "expected": null },
    { "input": "ex*ample.com", "expected": null },
    { "input": "*.*.com", "expected": null },
    { "input": "example.com/a{b}", "expected": null },
    { "input": "example.com/a:b", "expected": null },
    { "input": "http:example.com", "expected": null },
    { "input": "-münchen.de", "expected": null },
    { "input": "mün_chen.de", "expected": null },
    { "input": "a*b.münchen.de", "expected": null }
  ]
}
