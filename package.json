{
  "name": "geospoof-extension",
  "version": "1.0.0",
  "description": "Firefox extension for geolocation spoofing and location privacy",
  "scripts": {
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:property": "jest tests/property",
    "test:integration": "jest tests/integration",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "build": "npm run build:clean && npm run build:package",
    "build:clean": "rm -rf dist && mkdir -p dist",
    "build:package": "cd dist && zip -r ../geospoof-v$(node -p \"require('../package.json').version\").zip ../manifest.json ../background ../content ../popup ../icons -x '*.DS_Store' && cd .."
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0"
  }
}
