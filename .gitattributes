# Treat media and other binary assets as binary so Git never applies
# text/EOL normalization or UTF-8 re-encoding (which corrupts the bytes,
# e.g. turning invalid sequences into the U+FFFD replacement char and
# destroying MP4 moov atoms).
*.mp4   binary
*.webm  binary
*.mov   binary
*.m4v   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
